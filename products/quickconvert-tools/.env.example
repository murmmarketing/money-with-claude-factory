# QuickConvert environment variables
# Everything is OPTIONAL. With zero env set, the app builds and runs fine:
# all converters work (they run 100% in the browser) and Pro shows a
# "join waitlist / Pro coming soon" state instead of Stripe Checkout.

# --- Site ---
# Public base URL, used for canonical tags, sitemap and Stripe redirect URLs.
NEXT_PUBLIC_SITE_URL=https://quickconvert.tools

# --- Stripe (enables the Pro subscription checkout) ---
# When STRIPE_SECRET_KEY + STRIPE_PRO_PRICE_ID are present, the pricing page
# renders a real "Upgrade to Pro" button that opens Stripe Checkout.
STRIPE_SECRET_KEY=
# The recurring Price ID for the $5/mo (or $39/yr) Pro plan.
STRIPE_PRO_PRICE_ID=
# Optional yearly price ID; falls back to the monthly one if unset.
STRIPE_PRO_PRICE_ID_YEARLY=
# Webhook signing secret from the Stripe CLI / dashboard (records purchases).
STRIPE_WEBHOOK_SECRET=

# --- Ads (optional free-tier monetization) ---
# When set, the display ad slot renders on free tool pages.
# Example: your AdSense publisher id "ca-pub-XXXXXXXXXXXXXXXX".
NEXT_PUBLIC_AD_CLIENT=
# The ad unit / slot id.
NEXT_PUBLIC_AD_SLOT=
