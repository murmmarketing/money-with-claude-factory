# ResumeVault environment variables
# Everything is OPTIONAL. With none of these set, the site builds + deploys and
# shows a "Join the waitlist" flow instead of live Stripe Checkout.

# --- Stripe (one-time Checkout) ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_or_test_xxx
# Signing secret from the webhook endpoint you create in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Public site URL (used for Checkout success/cancel redirects + sitemap) ---
# No trailing slash. e.g. https://resumevault.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Download token secret ---
# Any long random string. Used to sign the token-gated /download links so buyers
# (and only buyers) can reach their files. If unset, a build-time default is used
# (fine for preview; set your own in production).
DOWNLOAD_TOKEN_SECRET=change-me-to-a-long-random-string

# --- Supabase (OPTIONAL) ---
# Only needed if you want waitlist emails + purchases persisted. Reuses the factory
# project. Tables are prefixed rv_ (rv_waitlist, rv_purchases). Without these the
# waitlist logs to the server console and Checkout still works fine.
NEXT_PUBLIC_SUPABASE_URL=https://tcatgldshmpgttmputzo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
