# ===== The Rep Playbook — environment =====
# Everything degrades gracefully when a var is absent (see README).
# With NOTHING set: the site builds, deploys, shows a clean waitlist, and the
# free Chapter 1 reader still works. Monetization switches on the moment the
# owner connects Stripe + Resend + a domain.

# --- Site ---
# Public origin used for absolute links, Stripe redirects, and magic links.
# Defaults to the current request host when unset.
NEXT_PUBLIC_SITE_URL=https://therepplaybook.com

# --- Supabase (persistence: orders, entitlements, leads, waitlist) ---
# Reuses the shared "factory" project with repplaybook_-prefixed tables.
NEXT_PUBLIC_SUPABASE_URL=https://tcatgldshmpgttmputzo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is server-only. Never expose it to the browser.
FACTORY_SERVICE_ROLE_KEY=your-service-role-key
# (SUPABASE_SERVICE_ROLE_KEY is also accepted as a fallback name.)

# --- Entitlement / passwordless login ---
# 32+ char random secret used to HMAC-sign the login cookie + magic links.
ENTITLEMENT_SECRET=change-me-to-a-long-random-string
# Salt for hashing one-time login codes at rest.
SERVER_SALT=change-me-too

# --- Email (Resend) — sends purchase magic links + login codes ---
# When absent, magic links / codes are NOT emailed; dev responses expose the
# code so you can still test end to end.
RESEND_API_KEY=
RESEND_FROM="The Rep Playbook <hello@therepplaybook.com>"

# --- Stripe (one-time purchase, pay-what-you-want) ---
# When STRIPE_SECRET_KEY is absent, checkout returns 503 "coming soon" and the
# UI shows a waitlist capture instead of crashing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: a pre-created one-time Price to use for the default $19 button.
# If unset, checkout builds the line item on the fly with price_data (PWYW),
# so you do NOT strictly need to create a Price to launch.
STRIPE_PRICE_PLAYBOOK=
