# ---------------------------------------------------------------------------
# MeaningAndSay environment variables
# Everything below is OPTIONAL. With zero env vars the site builds, deploys,
# and runs fine: pronunciation works, all pages render, and the premium pack
# checkout degrades to a "join the waitlist" flow.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical tags, sitemap, and Stripe redirect URLs).
# Falls back to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=https://meaningandsay.com

# --- Stripe (optional) ------------------------------------------------------
# When BOTH the secret key and a price ID are present, the $4 "pronunciation
# pack" checkout goes live. Otherwise the pricing page shows a waitlist form.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One Stripe Price (one-time, $4) reused for every category pack. The category
# slug is passed as checkout metadata so the success page delivers the right file.
STRIPE_PRICE_ID=

# --- Waitlist storage (optional) --------------------------------------------
# When the premium pack has no Stripe keys, the pricing page shows a waitlist.
# If these two are set, emails are inserted into the `meaningandsay_waitlist`
# table via Supabase's REST API (no SDK needed). If unset, signups are logged
# server-side and the UX still succeeds. Reuse the factory Supabase project.
#   Table SQL:
#   create table if not exists meaningandsay_waitlist (
#     id bigint generated always as identity primary key,
#     email text not null,
#     category text,
#     created_at timestamptz default now(),
#     unique (email)
#   );
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Display ads (optional) -------------------------------------------------
# When set, the ad slots render a real <ins> unit. When empty, slots collapse
# to nothing (no layout shift, no empty boxes).
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
