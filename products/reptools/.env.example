# ===== HaulHQ environment =====
# Everything degrades gracefully when a var is absent (see README).

# --- Site ---
# Public origin used for absolute links, OG images, Stripe redirects, share pages.
# Defaults to the current request host when unset.
NEXT_PUBLIC_SITE_URL=https://haulhq.app

# --- Supabase (persistence: hauls, entitlements, reference data) ---
NEXT_PUBLIC_SUPABASE_URL=https://tcatgldshmpgttmputzo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is server-only. Never expose to the browser.
FACTORY_SERVICE_ROLE_KEY=your-service-role-key
# (SUPABASE_SERVICE_ROLE_KEY is also accepted as a fallback name.)

# --- Entitlement / passwordless login ---
# 32+ char random secret used to HMAC-sign the login cookie. REQUIRED for Pro login.
ENTITLEMENT_SECRET=change-me-to-a-long-random-string
# Salt for hashing one-time login codes at rest.
SERVER_SALT=change-me-too

# --- Email (Resend) — sends login codes + price-watch reminders ---
# When absent, login codes are NOT emailed (dev responses expose the code instead).
RESEND_API_KEY=
RESEND_FROM="HaulHQ <login@haulhq.app>"

# --- Stripe (Pro subscriptions) ---
# When STRIPE_SECRET_KEY is absent, checkout returns 503 "coming soon" and the
# UI shows a waitlist capture instead of crashing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_yyy

# --- Cron protection ---
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET`. When unset the route
# still runs but logs a warning.
CRON_SECRET=change-me-cron

# --- Storage ---
# Supabase Storage bucket for QC photos (create it, public read).
QC_BUCKET=qc-photos
