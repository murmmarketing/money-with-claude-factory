# factory.env.example — template for ~/money-with-claude-factory/.factory.env
# The real .factory.env is gitignored and holds secrets. run-factory.sh sources it and
# exports every key below so both the ops layer and claude's Bash tool inherit them.
# Copy the keys you need into .factory.env (keep the `export` form). Empty is safe —
# every consumer degrades gracefully when a token is missing.

# --- Telegram control channel ---
export TG_TOKEN=
export TG_CHAT=

# --- Factory Supabase (project tcatgldshmpgttmputzo) ---
export FACTORY_SUPABASE_URL=
export FACTORY_SUPABASE_ANON_KEY=
# Service-role key: required for compute_scores RPC + writing pipeline/landing/scores rows.
export FACTORY_SERVICE_ROLE_KEY=

# --- Validation pipeline creds (used by pipeline/validate.mjs; O3) ---
export DATAFORSEO_LOGIN=
export DATAFORSEO_PASSWORD=
export META_AD_LIBRARY_TOKEN=
export REDDIT_UA=

# --- healthchecks.io dead-man switch (O1) ---
# Base check URL for the hourly run. run-factory pings $HC_URL/start on acquire and
# $HC_URL/<exit-code> (or /fail on a tripped breaker) on exit.
export HC_URL=
# Separate check for the 15-min watchdog so a dead runner is still noticed.
export HC_WATCHDOG_URL=

# --- Optional ops knobs ---
# Launchpad health endpoint the watchdog probes (e.g. https://<domain>/api/health).
export LAUNCHPAD_HEALTH_URL=
# Staleness threshold (seconds) before healthcheck flags the runner. Default 7200 (2h).
export STALE_SECONDS=7200
